import os
import sys
import time
import queue
import threading
import subprocess
import shutil
import tkinter as tk
from datetime import datetime
import configparser

import pytchat
from playsound3 import playsound

# --- ตรวจเช็กไฟล์ Config ก่อนเริ่ม ---
if not os.path.exists("config.ini"):
    print("❌ ไม่พบไฟล์ config.ini กรุณาสร้างไฟล์ก่อน!")
    sys.exit()

config = configparser.ConfigParser()
config.read("config.ini")

try:
    YOUTUBE_VIDEO_ID = config.get("settings", "YOUTUBE_VIDEO_ID")
    VOICE = config.get("settings", "VOICE")
    DELAY_PER_CHAR = config.getfloat("settings", "DELAY_PER_CHAR")
    MAX_DELAY = config.getfloat("settings", "MAX_DELAY")
    CLEAR_EVERY = config.getint("settings", "CLEAR_EVERY")
except Exception as e:
    print(f"❌ ตั้งค่าใน config.ini ไม่ถูกต้อง: {e}")
    sys.exit()

CACHE_DIR = "tts_cache"
os.makedirs(CACHE_DIR, exist_ok=True)
tts_queue = queue.Queue()
running = True

def log(msg):
    print(f"[{datetime.now().strftime('%H:%M:%S')}] {msg}")

def start_gui():
    root = tk.Tk()
    # root.withdraw() # ปิดไว้ก่อนเพื่อดูว่า GUI ขึ้นไหมตอน Debug
    root.title("Debug Mode")
    root.mainloop()

def tts_worker():
    while running:
        try:
            text = tts_queue.get(timeout=1)
        except queue.Empty:
            continue
        if text is None: break

        filename = os.path.join(CACHE_DIR, f"tts_{int(time.time()*1000)}.mp3")
        cmd = [sys.executable, "-m", "edge_tts", "--voice", VOICE, "--text", text, "--write-media", filename]

        try:
            result = subprocess.run(cmd, capture_output=True, text=True, creationflags=0x08000000)
            if result.returncode != 0:
                log(f"❌ edge-tts Error: {result.stderr}")
                continue

            if os.path.exists(filename):
                playsound(filename)
                os.remove(filename)
        except Exception as e:
            log(f"❌ Playback Error: {e}")
        tts_queue.task_done()

def main():
    global running
    log(f"🚀 กำลังเชื่อมต่อ YouTube ID: {YOUTUBE_VIDEO_ID}")
    
    worker = threading.Thread(target=tts_worker, daemon=True)
    worker.start()

    try:
        chat = pytchat.create(video_id=YOUTUBE_VIDEO_ID)
        if not chat.is_alive():
            log("❌ ไม่สามารถดึงแชทได้ (ID อาจผิด หรือไลฟ์จบแล้ว)")
            return

        log("✅ เชื่อมต่อสำเร็จ! รอรับข้อความแชท...")
        while running and chat.is_alive():
            for c in chat.get().sync_items():
                msg = f"{c.author.name} พูดว่า {c.message}"
                log(f"💬 {msg}")
                tts_queue.put(msg)
            time.sleep(0.5)
    except Exception as e:
        log(f"⚠️ Main Loop Error: {e}")
    finally:
        running = False
        log("⛔ โปรแกรมหยุดทำงาน")

if __name__ == "__main__":
    main()